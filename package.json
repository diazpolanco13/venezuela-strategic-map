{
  "name": "venezuela-strategic-map",
  "private": false,
  "version": "1.0.0",
  "description": "Mapa estratégico interactivo de Venezuela con capas GeoJSON, REDI, Guayana Esequiba y geolocalización",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:outline": "node --experimental-strip-types scripts/build-ven-outline.mjs",
    "simplify:geo": "node scripts/simplify-geo.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "framer-motion": "^11.15.0",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.9",
    "@turf/turf": "^7.3.4",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "mapshaper": "^0.6.113",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.3",
    "vite": "^6.0.3"
  }
}
